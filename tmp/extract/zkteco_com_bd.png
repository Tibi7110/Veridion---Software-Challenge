<style>
    @media (min-width: 768px) {
        .popup {
            width: 448px;
            height: 504px;
        }
    }

    /* 手机端样式 */
    @media (max-width: 767px) {
        .popup {
            width: 80%;
            height: 80%;
        }
    }
    .floating-image {
        position: fixed;
        right: 110px;
        bottom: 60px;
        z-index: 9999;
        width: 20%;
    }
    
    .floating-image img{       
        width:100%;
    }
     /* 手机端适配 */
    @media (max-width: 768px) {
        .floating-image {
            right: auto; /* 清除右侧定位 */
            bottom: auto; /* 清除底部定位 */
            left: 50%; /* 水平居中 */
            top: 50%; /* 垂直居中 */
            transform: translate(-50%, -50%); /* 精确居中补偿 */
            width: 75%;
        }
    }
    /* 视频播放 */
    .video-container {
        position: fixed;
        width: 400px;
        height: 350px;
        z-index: 9999;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
        border-radius: 8px;
        overflow: hidden;
        background-color: #000;
    }

    .video-container iframe {
      width: 100%;
      height: 100%;
      border: none;
    }

    .close-btn {
      position: absolute;
      top: 15px;
      right: 5px;
      /*background: rgba(0,0,0,0.6);*/
      color: #fff;
      border: none;
      font-size: 18px;
      cursor: pointer;
      border-radius: 50%;
      width: 28px;
      height: 28px;
      line-height: 26px;
      text-align: center;
    }

    /* PC端：右下角播放 */
    @media (min-width: 768px) {
      .video-container {
        bottom: 60px;
        right: 110px;
      }
    }

    /* 手机端：居中播放 */
    @media (max-width: 767px) {
      .video-container {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }
    }
</style>
